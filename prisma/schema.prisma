// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id             String            @id @default(dbgenerated("gen_random_uuid()"))
  uuid           String            @unique @default(cuid())
  name           String
  last_name      String
  username       String            @unique @db.VarChar(30)
  email          String            @unique
  email_verified Boolean           @default(false)
  image          String?
  created_at     DateTime          @default(now())
  role           UserRoles         @default(STAFF)
  updated_at     DateTime          @updatedAt
  sessions       UserSession[]     @relation("session:user")
  accounts       UserAccount[]     @relation("account:user")
  products       Product[]         @relation("product:user")
  permissions    UserPermissions[] @relation("user_permissions:user")
  logs           UserLogs[]        @relation("user_logs:user")

  @@index([role]) // Búsquedas por rol (listar staff, admins, etc.)
  @@index([created_at]) // Ordenar usuarios por fecha de creación
  @@map("user")
}

model UserSession {
  id         String   @id @default(dbgenerated("gen_random_uuid()"))
  expires_at DateTime
  token      String   @unique
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt
  ip_address String?
  user_agent String?
  user_id    String
  user       User     @relation("session:user", fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id]) // Buscar sesiones de un usuario específico
  @@index([expires_at]) // Limpiar sesiones expiradas
  @@map("user_session")
}

model UserAccount {
  id                       String    @id @default(dbgenerated("gen_random_uuid()"))
  //google user id, email, github user id, etc
  account_id               String
  //credentials,google,facebook...
  provider_id              String
  user_id                  String
  access_token             String?
  refresh_token            String?
  id_token                 String?
  access_token_expires_at  DateTime?
  refresh_token_expires_at DateTime?
  scope                    String?
  password                 String?
  created_at               DateTime  @default(now())
  updated_at               DateTime  @updatedAt
  user                     User      @relation("account:user", fields: [user_id], references: [id], onDelete: Cascade)

  @@unique([provider_id, account_id])
  @@index([user_id]) // Buscar cuentas de un usuario
  @@map("user_account")
}

model UserPermissions {
  id          String       @id @default(cuid())
  user_id     String
  module      UserModules
  permissions Permission[]
  added_at    DateTime     @default(now())
  updated_at  DateTime     @updatedAt
  user        User         @relation("user_permissions:user", fields: [user_id], references: [id], onDelete: Cascade)

  @@unique([user_id, module]) // Un usuario solo puede tener un registro de permisos por módulo
  @@index([user_id]) // Buscar permisos de un usuario
  @@index([module]) // Buscar usuarios con permisos en un módulo específico
  @@map("user_permissions")
}

model UserLogs {
  id          String   @id @default(cuid())
  user_id     String
  description String
  created_at  DateTime @default(now())
  user        User     @relation("user_logs:user", fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id]) // Buscar logs de un usuario
  @@index([created_at]) // Ordenar logs por fecha
  @@map("user_logs")
}

model Verification {
  id         String   @id @default(cuid())
  identifier String
  value      String
  expires_at DateTime
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@unique([identifier, value])
  @@index([expires_at]) // Limpiar verificaciones expiradas
  @@map("verification")
}

model Customer {
  id                 String                  @id @default(dbgenerated("gen_random_uuid()"))
  uuid               String                  @unique @default(cuid())
  name               String
  last_name          String
  email              String                  @unique
  email_verified     Boolean                 @default(false)
  image              String?
  created_at         DateTime                @default(now())
  updated_at         DateTime                @updatedAt
  sessions           CustomerSession[]       @relation("customer_session:customer")
  accounts           CustomerAccount[]       @relation("customer_account:customer")
  favorites          CustomerFavorites[]     @relation("customer_favorites:customer")
  customer_addresses CustomerAddresses[]     @relation("customer_address:customer")
  orders             Order[]                 @relation("order:customer")
  reviews            ProductVersionReviews[] @relation("product_version_reviews:customer")
  shopping_carts     ShoppingCart[]          @relation("shopping_cart:customer")

  @@index([email]) // Búsquedas por email
  @@index([created_at]) // Ordenar clientes por fecha de registro
  @@map("customer")
}

model CustomerSession {
  id          String   @id @default(dbgenerated("gen_random_uuid()"))
  expires_at  DateTime
  token       String   @unique
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt
  ip_address  String?
  user_agent  String?
  customer_id String
  customer    Customer @relation("customer_session:customer", fields: [customer_id], references: [id], onDelete: Cascade)

  @@index([customer_id]) // Buscar sesiones de un cliente
  @@index([expires_at]) // Limpiar sesiones expiradas
  @@map("customer_session")
}

model CustomerAccount {
  id                       String    @id @default(dbgenerated("gen_random_uuid()"))
  account_id               String
  provider_id              String
  customer_id              String
  access_token             String?
  refresh_token            String?
  id_token                 String?
  access_token_expires_at  DateTime?
  refresh_token_expires_at DateTime?
  scope                    String?
  password                 String?
  created_at               DateTime  @default(now())
  updated_at               DateTime  @updatedAt
  customer                 Customer  @relation("customer_account:customer", fields: [customer_id], references: [id], onDelete: Cascade)

  @@unique([provider_id, account_id])
  @@index([customer_id]) // Buscar cuentas de un cliente
  @@map("customer_account")
}

model Category {
  id            String          @id @default(dbgenerated("gen_random_uuid()"))
  uuid          String          @unique @default(cuid())
  name          String          @unique
  created_at    DateTime        @default(now())
  updated_at    DateTime        @updatedAt
  subcategories Subcategories[] @relation("subcategories:category")
  products      Product[]       @relation("product:category")

  @@index([name]) // Búsquedas por nombre de categoría
  @@map("category")
}

model Subcategories {
  id                    String                 @id @default(dbgenerated("gen_random_uuid()"))
  uuid                  String                 @unique @default(cuid())
  category_id           String
  description           String
  level                 Int
  father_id             String?
  father_uuid           String?
  created_at            DateTime               @default(now())
  updated_at            DateTime               @updatedAt
  category              Category               @relation("subcategories:category", fields: [category_id], references: [id])
  parent                Subcategories?         @relation("parent:child", fields: [father_id], references: [id])
  children              Subcategories[]        @relation("parent:child")
  product_subcategories ProductSubcategories[] @relation("product_subcategories:subcategories")

  @@index([category_id]) // Buscar subcategorías de una categoría
  @@index([father_id]) // Buscar hijos de una subcategoría padre
  @@index([level]) // Filtrar por nivel de jerarquía
  @@map("subcategories")
}

model ProductResources {
  id                   String   @id @default(cuid())
  product_id           String
  resource_description String
  resource_url         String
  created_at           DateTime @default(now())
  updated_at           DateTime @updatedAt
  product              Product  @relation("product_sources:product", fields: [product_id], references: [id])

  @@index([product_id]) // Buscar recursos de un producto
  @@map("product_resources")
}

model ProductSubcategories {
  product_id     String
  subcategory_id String
  product        Product       @relation("product_subcategories:product", fields: [product_id], references: [id])
  subcategories  Subcategories @relation("product_subcategories:subcategories", fields: [subcategory_id], references: [id])

  @@id([product_id, subcategory_id])
  @@index([subcategory_id]) // Buscar productos de una subcategoría
  @@map("product_subcategories")
}

model Product {
  id                  String                 @id @default(dbgenerated("gen_random_uuid()"))
  uuid                String                 @unique @default(cuid())
  product_name        String                 @unique
  category_id         String
  description         String
  specs               String
  recommendations     String
  applications        String
  certifications_desc String
  created_at          DateTime               @default(now())
  updated_at          DateTime               @updatedAt
  user_id             String
  category            Category               @relation("product:category", fields: [category_id], references: [id])
  user                User                   @relation("product:user", fields: [user_id], references: [id], onDelete: Restrict)
  product_resources   ProductResources[]     @relation("product_sources:product")
  subcategories       ProductSubcategories[] @relation("product_subcategories:product")
  product_versions    ProductVersion[]       @relation("product_version:product")

  @@index([category_id]) // Filtrar productos por categoría
  @@index([user_id]) // Buscar productos creados por un usuario
  @@index([created_at]) // Ordenar productos por fecha de creación
  @@index([product_name]) // Búsquedas por nombre (aunque ya es unique, mejora performance en búsquedas parciales)
  @@map("product")
}

model ProductVersion {
  id                     String                  @id @default(dbgenerated("gen_random_uuid()"))
  product_id             String
  sku                    String                  @unique
  code_bar               String?                 @unique
  color_line             String
  color_name             String
  color_code             String
  status                 String
  stock                  Int                     @default(0)
  unit_price             Decimal                 @db.Decimal(10, 2)
  technical_sheet_url    String                  @default("N/A")
  created_at             DateTime                @default(now())
  updated_at             DateTime                @updatedAt
  main_version           Boolean                 @default(false)
  product                Product                 @relation("product_version:product", fields: [product_id], references: [id])
  customer_favorites     CustomerFavorites[]     @relation("customer_favorites:product_version")
  order_items            OrderItemsDetails[]     @relation("order_items_details:product_version")
  product_version_images ProductVersionImages[]  @relation("product_version_images:product_version")
  reviews                ProductVersionReviews[] @relation("product_version_reviews:product_version")
  shopping_cart_items    ShoppingCartItems[]     @relation("shopping_cart_items:product_version")

  @@index([product_id]) // Buscar versiones de un producto
  @@index([status]) // Filtrar por estado (activo, descontinuado, etc.)
  @@index([stock]) // Filtrar productos con/sin stock
  @@index([main_version]) // Buscar versión principal de productos
  @@map("product_version")
}

model ProductVersionImages {
  id                 String         @id @default(cuid())
  product_version_id String
  image_url          String
  main_image         Boolean        @default(false)
  product_version    ProductVersion @relation("product_version_images:product_version", fields: [product_version_id], references: [id], onDelete: Cascade)

  @@index([product_version_id]) // Buscar imágenes de una versión
  @@index([main_image]) // Buscar imagen principal
  @@map("product_version_images")
}

model CustomerFavorites {
  id                 String         @id @default(cuid())
  customer_id        String
  product_version_id String
  added_at           DateTime       @default(now())
  customer           Customer       @relation("customer_favorites:customer", fields: [customer_id], references: [id])
  product_version    ProductVersion @relation("customer_favorites:product_version", fields: [product_version_id], references: [id])

  @@unique([customer_id, product_version_id]) // Un cliente no puede tener duplicados en favoritos
  @@index([customer_id]) // Buscar favoritos de un cliente
  @@index([product_version_id]) // Contar cuántos clientes tienen este producto en favoritos
  @@map("customer_favorites")
}

model CustomerAddresses {
  id                     String   @id @default(cuid())
  uuid                   String   @unique @default(cuid())
  customer_id            String
  recipient_name         String   @db.VarChar(40)
  recipient_last_name    String   @db.VarChar(60)
  country                String   @db.VarChar(40)
  state                  String   @db.VarChar(40)
  city                   String   @db.VarChar(50)
  locality               String   @db.VarChar(50)
  street_name            String   @db.VarChar(60)
  neighborhood           String   @db.VarChar(60)
  zip_code               String   @db.VarChar(10)
  address_type           String   @db.VarChar(30)
  floor                  String?  @default("N/A") @db.VarChar(3)
  number                 String   @db.VarChar(10)
  aditional_number       String?  @default("N/A") @db.VarChar(10)
  references_or_comments String?  @default("N/A") @db.VarChar(80)
  country_phone_code     String   @db.VarChar(4)
  contact_number         String   @db.VarChar(15)
  default_address        Boolean
  created_at             DateTime @default(now())
  updated_at             DateTime @updatedAt
  customer               Customer @relation("customer_address:customer", fields: [customer_id], references: [id], onDelete: Cascade)
  orders                 Order[]  @relation("order:customer_addresses")

  @@index([customer_id]) // Buscar direcciones de un cliente
  @@index([default_address]) // Buscar dirección por defecto
  @@map("customer_addresses")
}

model Order {
  id                     String                @id @default(cuid())
  uuid                   String                @unique @default(dbgenerated("gen_random_uuid()"))
  external_order_id      String                @unique
  customer_id            String?
  customer_address_id    String?
  is_guest_order         Boolean               @default(false)
  payment_provider       String
  status                 OrderAndPaymentStatus
  total_amount           Decimal               @db.Decimal(10, 2)
  exchange               String
  aditional_resource_url String?
  coupon_code            String?
  created_at             DateTime              @default(now())
  updated_at             DateTime              @updatedAt
  customer_address       CustomerAddresses?    @relation("order:customer_addresses", fields: [customer_address_id], references: [id])
  customer               Customer?             @relation("order:customer", fields: [customer_id], references: [id])
  payment_details        OrderPaymentDetails[] @relation("order_payment_details:order")
  order_items            OrderItemsDetails[]   @relation("order_items_details:order")
  shipping               Shipping?             @relation("shipping:order")

  @@index([customer_id]) // Buscar órdenes de un cliente
  @@index([status]) // Filtrar órdenes por estado
  @@index([created_at]) // Ordenar órdenes por fecha
  @@index([payment_provider]) // Filtrar por proveedor de pago
  @@index([coupon_code]) // Buscar órdenes que usaron un cupón específico
  @@map("order")
}

model OrderPaymentDetails {
  id                          Int                   @id @default(autoincrement())
  order_id                    String
  payment_id                  BigInt                @unique
  last_four_digits            String
  payment_class               String
  payment_method              String
  customer_paid_amount        Decimal               @db.Decimal(10, 2)
  received_amount             Decimal               @db.Decimal(10, 2)
  fee_amount                  Decimal?              @db.Decimal(10, 2)
  customer_installment_amount Decimal               @db.Decimal(10, 2)
  installments                Int
  payment_status              OrderAndPaymentStatus
  created_at                  DateTime              @default(now())
  updated_at                  DateTime              @updatedAt
  order                       Order                 @relation("order_payment_details:order", fields: [order_id], references: [id])

  @@index([order_id]) // Buscar pagos de una orden
  @@index([payment_status]) // Filtrar pagos por estado
  @@index([payment_method]) // Reportes por método de pago
  @@map("order_payment_details")
}

model OrderItemsDetails {
  id                 Int            @id @default(autoincrement())
  order_id           String
  product_version_id String
  quantity           Int
  unit_price         Decimal        @db.Decimal(10, 2)
  discount           Int            @default(0)
  subtotal           Decimal        @db.Decimal(10, 2)
  order              Order          @relation("order_items_details:order", fields: [order_id], references: [id])
  product_version    ProductVersion @relation("order_items_details:product_version", fields: [product_version_id], references: [id])

  @@index([order_id]) // Buscar items de una orden
  @@index([product_version_id]) // Reportes de ventas por producto
  @@map("order_items_details")
}

model Shipping {
  id               String         @id @default(cuid())
  uuid             String         @unique @default(dbgenerated("gen_random_uuid()"))
  order_id         String         @unique
  shipping_status  ShippingStatus
  concept          String
  tracking_number  String?
  carrier          String?
  shipping_amount  Decimal        @db.Decimal(10, 2)
  insurance_amount Decimal?       @db.Decimal(10, 2)
  boxes_count      Int
  created_at       DateTime       @default(now())
  updated_at       DateTime       @updatedAt
  order            Order          @relation("shipping:order", fields: [order_id], references: [id])

  @@index([shipping_status]) // Filtrar envíos por estado
  @@index([tracking_number]) // Buscar por número de rastreo
  @@index([carrier]) // Filtrar por transportista
  @@map("shipping")
}

model Offers {
  id                  String        @id @default(cuid())
  uuid                String        @unique @default(cuid())
  description         String
  discount_percentage Int
  code                String?       @unique
  type                OfferType
  status              OfferStatus
  start_date          DateTime
  end_date            DateTime
  max_uses            Int?
  current_uses        Int           @default(0)
  created_at          DateTime      @default(now())
  updated_at          DateTime      @updatedAt
  offer_targets       OfferTarget[] @relation("offer_target:offers")

  @@index([status]) // Filtrar ofertas activas/pausadas
  @@index([type]) // Filtrar por tipo de oferta
  @@index([start_date, end_date]) // Buscar ofertas vigentes
  @@index([code]) // Búsqueda rápida de cupones
  @@map("offers")
}

model OfferTarget {
  id               String          @id @default(cuid())
  offer_id         String
  target_type      OfferTargetType
  target_id        String?
  target_uuid_path String[]        @default([])
  offer            Offers          @relation("offer_target:offers", fields: [offer_id], references: [id], onDelete: Cascade)

  @@unique([offer_id, target_type, target_id])
  @@index([target_type, target_id]) // Ya existe, perfecto para buscar ofertas aplicables
  @@index([offer_id]) // Buscar targets de una oferta
  @@map("offer_target")
}

model ProductVersionReviews {
  id                 String         @id @default(cuid())
  uuid               String         @unique @default(cuid())
  product_version_id String
  customer_id        String
  rating             Int
  title              String
  comment            String
  created_at         DateTime       @default(now())
  product_version    ProductVersion @relation("product_version_reviews:product_version", fields: [product_version_id], references: [id], onDelete: Cascade)
  customer           Customer       @relation("product_version_reviews:customer", fields: [customer_id], references: [id], onDelete: Cascade)

  @@unique([product_version_id, customer_id]) // Un cliente solo puede dejar una reseña por producto
  @@index([product_version_id]) // Buscar reseñas de un producto
  @@index([customer_id]) // Buscar reseñas de un cliente
  @@index([rating]) // Filtrar por calificación
  @@index([created_at]) // Ordenar reseñas por fecha
  @@map("product_version_reviews")
}

model ShoppingCart {
  id          String              @id @default(dbgenerated("gen_random_uuid()"))
  customer_id String              @unique
  status      ShoppingCartStatus  @default(ACTIVE)
  updated_at  DateTime            @updatedAt
  customer    Customer            @relation("shopping_cart:customer", fields: [customer_id], references: [id], onDelete: Cascade)
  items       ShoppingCartItems[] @relation("shopping_cart_items:shopping_cart")

  @@index([status]) // Buscar carritos abandonados
  @@index([updated_at]) // Limpiar carritos antiguos
  @@map("shopping_cart")
}

model ShoppingCartItems {
  id                 String         @id @default(dbgenerated("gen_random_uuid()"))
  uuid               String         @unique @default(cuid())
  shopping_cart_id   String
  product_version_id String
  quantity           Int            @default(1)
  is_checked         Boolean        @default(true)
  updated_at         DateTime       @updatedAt
  shopping_cart      ShoppingCart   @relation("shopping_cart_items:shopping_cart", fields: [shopping_cart_id], references: [id], onDelete: Cascade)
  product_version    ProductVersion @relation("shopping_cart_items:product_version", fields: [product_version_id], references: [id], onDelete: Cascade)

  @@unique([shopping_cart_id, product_version_id])
  @@index([shopping_cart_id]) // Buscar items de un carrito
  @@index([product_version_id]) // Reportes de productos más agregados al carrito
  @@map("shopping_cart_items")
}

enum ShoppingCartStatus {
  ACTIVE
  ABANDONED
  CONVERTED
}

enum UserModules {
  USERS
  CATEGORIES
  SUBCATEGORIES
  PRODUCTS
  CUSTOMERS
  ORDERS
  E_COMMERCE_PAGE
  OFFERS
  E_COMMERCE_METRICS
}

// ENUMS
enum UserRoles {
  SUPERUSER
  ADMIN
  STAFF
}

enum Permission {
  CREATE
  READ
  UPDATE
  DELETE
}

enum OfferType {
  PERCENTAGE
  COUPON
}

enum OfferTargetType {
  PRODUCT // Aplica a un producto y TODAS sus versiones
  CATEGORY // Aplica a toda una categoría
  SUBCATEGORY // Aplica a productos con ruta de subcategorías
  PRODUCT_VERSION // Aplica a una versión específica de producto
}

enum OfferStatus {
  ACTIVE
  PAUSED
  ENDED
  CANCELLED
  PENDING
}

enum OrderAndPaymentStatus {
  APPROVED
  REJECTED
  IN_PROCESS
  CANCELLED
  AUTHORIZED
  PENDING
  REFUNDED
  IN_MEDIATION
  CHARGED_BACK
}

enum ShippingStatus {
  PENDING
  SHIPPED
  DELIVERED
  CANCELLED
  IN_PROCESS
  IN_TRANSIT
  RETURNED
  RETURNED_IN_PROCESS
  RETURNED_DELIVERED
  IN_PREPARATION
  STAND_BY
}
